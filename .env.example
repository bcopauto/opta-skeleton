DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=orchestrator_db
POSTGRES_USER=orchestrator_user
POSTGRES_PASSWORD=orchestrator_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

PYTHON_SERVICE_1_URL=http://sr_parsing:8001
PYTHON_SERVICE_2_URL=http://sr_analysis:6969
GO_SERVICE_URL=http://sr_psi_go:8003

# --- SerpAPI ---
SERPAPI_API_KEY=your-serpapi-key-here

# --- Scraper Service (sr_parsing) ---
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF=1.0
SCRAPER_MAX_PAGES_PER_JOB=100
SCRAPER_MAX_CONCURRENT_REQUESTS=10
SCRAPER_PROXY_URL=
SCRAPER_USE_PROXY=false
SCRAPER_ROBOTS_TIMEOUT=10
SCRAPER_LOG_LEVEL=INFO
SCRAPER_DEBUG_DUMP_DIR=
SCRAPER_MIN_BODY_CHARS=500
SCRAPER_HEADLESS=true
SCRAPER_MYSQL_CONNECTION_STRING=mysql+aiomysql://scraper:scraper_pass@mysql:3306/scraper_db
SCRAPER_PAGESPEED_API_KEY=

# --- MySQL ---
MYSQL_ROOT_PASSWORD=scraper_root
MYSQL_DATABASE=scraper_db
MYSQL_USER=scraper
MYSQL_PASSWORD=scraper_pass

# --- Analysis Service (sr_analysis) ---
ANALYSIS_GEMINI_API_KEY=your-gemini-api-key-here
ANALYSIS_GEMINI_MODEL=gemini-2.5-flash
ANALYSIS_PORT=6969
ANALYSIS_MAX_CONCURRENT_GEMINI_CALLS=3
ANALYSIS_TOKEN_CEILING_PER_MODULE=100000
ANALYSIS_LOG_LEVEL=INFO
ANALYSIS_MAX_CONCURRENT_JOBS=10
ANALYSIS_JOB_TTL_MINUTES=60